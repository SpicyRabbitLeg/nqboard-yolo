# ==============================================
# 视频AI服务 环境变量配置文件 (.env)
# 与 settings.py 完全对应，可直接使用
# ==============================================

# ------------------- 应用信息 -------------------
VERSION=2026.0.0
APP_NAME=Video AI Service
APP_HOST=0.0.0.0
APP_PORT=9007
APP_DEBUG=True

# ------------------- Redis 配置 ----------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ------------------- YOLO 识别阈值 -------------
YOLO_CONFIDENCE=0.5
YOLO_IOU=0.45

# ------------------- 模型文件路径 ---------------
YOLO_ANIMAL_MODEL_PATH=yolo11m.pt
# 模型地址 https://huggingface.co/leeyunjai/yolo11-firedetect/blob/main/firedetect-11s.pt   PS:【下载不了，请直接到网站下载好放入根目录】
YOLO_FIRE_MODEL_PATH=yolo11-firedetect.pt
# 模型地址 https://huggingface.co/keremberke/yolov8m-hard-hat-detection/blob/main/best.pt   PS:【下载不了，请直接到网站下载好放入根目录】
YOLO_HARDHAT_MODEL_PATH=yolo11-hardhat.pt

# ------------------- 回调接口配置 ---------------
CALLBACK_TIMEOUT=5
STATUS_INTERVAL=5

# ------------------- 视频流处理 ----------------
RTSP_TIMEOUT=10
FRAME_SKIP=5
MAX_CONSECUTIVE_READ_FAILURES=10
INITIAL_RECONNECT_DELAY=3
MAX_RECONNECT_DELAY=30
PERSON_STAY_THRESHOLD=5.0
PERSON_ABSENCE_RESET=2.0

# ------------------- 支持的识别类型 -------------
# 两种写法都支持：逗号分隔 或 JSON数组
SUPPORTED_TYPES=CAT,DOG,FIRE,HARDHAT,NO_HARDHAT,PERSON

# ------------------- 日志配置 -------------------
LOG_LEVEL=INFO
LOG_ROTATION=10 MB
LOG_RETENTION=30 days